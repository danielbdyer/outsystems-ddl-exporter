<?xml version="1.0" encoding="utf-8"?>
<!--
  Repository-local NuGet sources. `<clear />` drops every source inherited from a
  machine-/user-level NuGet.config (e.g. a proprietary corporate feed) so `dotnet
  restore` resolves only from nuget.org. Add internal feeds below the nuget.org line
  if/when a package genuinely requires one.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
