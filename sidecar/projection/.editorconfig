# Sidecar-scoped formatting. Does not affect the trunk.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.fs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.fsproj]
indent_style = space
indent_size = 2

[*.{md,json,sln}]
indent_style = space
indent_size = 2
