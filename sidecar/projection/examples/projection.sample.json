{
  "model": { "ossys": "file:./secrets/ossys.conn" },

  "overrides": {
    "tableRenames": [
      { "from": { "module": "Sales", "entity": "Cust" }, "to": { "schema": "dbo", "table": "Customer" } }
    ]
  },

  "emission": { "ssdt": true, "dacpac": true },

  "policy": {
    "_comment": "OPT-IN, not baseline. Omit this whole block for faithful vanilla emission (the default skeleton imposes no tightening). Each interventions entry is a TRACKED operator override of the team's model — shown here only to illustrate the shape.",
    "tightening": { "interventions": [ { "kind": "nullability", "id": "n1", "nullBudget": 0.0 } ] }
  },

  "environments": {
    "onprem-dev":    { "access": "bundle", "out": "./dist/onprem-dev", "grant": "schema+data", "rendition": "logical" },
    "onprem-qa":     { "access": "bundle", "out": "./dist/onprem-qa",  "grant": "schema+data", "rendition": "logical" },
    "onprem-uat":    { "access": "bundle", "out": "./dist/onprem-uat", "grant": "schema+data", "rendition": "logical", "store": "lifecycle/onprem-uat.json" },

    "onprem-legacy": { "access": "direct", "conn": "file:./secrets/onprem-legacy.conn", "rendition": "logical" },

    "cloud-qa":      { "access": "direct", "conn": "file:./secrets/cloud-qa.conn", "rendition": "physical" },

    "cloud-uat":     { "access": "direct", "conn": "file:./secrets/cloud-uat.conn", "grant": "data", "rendition": "physical", "store": "lifecycle/cloud-uat.json" }
  },

  "flows": {
    "publish":  { "from": "model", "to": "onprem-uat" },

    "skeleton": { "from": "model", "to": "onprem-dev", "shape": "skeleton" },

    "audit":    { "from": "model", "to": "onprem-dev", "shaping": { "model": { "modules": ["Ops"] } } },

    "golden":   { "from": "cloud-qa", "to": "cloud-uat", "scope": "data", "tables": ["Customer", "Order", "OrderLine"], "rekey": "file:./secrets/users.csv" },

    "preview":  { "from": "onprem-legacy", "to": "cloud-uat", "scope": "data" },

    "synth":    { "from": "synthetic", "to": "cloud-uat", "profile": "cloud-qa" }
  }
}
