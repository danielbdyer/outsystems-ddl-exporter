<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RootNamespace>Projection.Pipeline</RootNamespace>
    <AssemblyName>Projection.Pipeline</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Config.fs" />
    <Compile Include="CatalogResolution.fs" />
    <Compile Include="LogSink.fs" />
    <Compile Include="EventProjection.fs" />
    <Compile Include="RunLedger.fs" />
    <Compile Include="Run.fs" />
    <Compile Include="Source.fs" />
    <Compile Include="Ref.fs" />
    <Compile Include="RunHistory.fs" />
    <Compile Include="ApprovalStore.fs" />
    <Compile Include="LifecycleStore.fs" />
    <Compile Include="RenameBinding.fs" />
    <Compile Include="TighteningBinding.fs" />
    <Compile Include="SpecialCircumstancesBinding.fs" />
    <Compile Include="SpecialCircumstancesDiagnostics.fs" />
    <Compile Include="InactiveAttributeDiagnostics.fs" />
    <Compile Include="FkSelectivityDiagnostics.fs" />
    <Compile Include="JointDependencyDiagnostics.fs" />
    <Compile Include="EmissionFoldersBinding.fs" />
    <Compile Include="TransformGroupsBinding.fs" />
    <Compile Include="InsertionPolicyBinding.fs" />
    <Compile Include="LiveModelRead.fs" />
    <Compile Include="Pipeline.fs" />
    <Compile Include="PolicyDiff.fs" />
    <Compile Include="Bulk.fs" />
    <Compile Include="Deploy.fs" />
    <Compile Include="BenchSink.fs" />
    <Compile Include="Preflight.fs" />
    <Compile Include="RenameProjection.fs" />
    <Compile Include="TransferRun.fs" />
    <Compile Include="MigrationRun.fs" />
    <Compile Include="DriftRun.fs" />
    <Compile Include="EjectRun.fs" />
    <Compile Include="ReportRun.fs" />
    <Compile Include="TransferSpec.fs" />
    <Compile Include="ModelResolution.fs" />
    <Compile Include="SyntheticLoadRun.fs" />
    <Compile Include="ProfileCaptureRun.fs" />
    <Compile Include="MovementSpec.fs" />
    <Compile Include="MovementSurface.fs" />
    <Compile Include="CapabilitySurvey.fs" />
    <Compile Include="RegisteredAllTransforms.fs" />
    <Compile Include="FullExportRun.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Testcontainers.MsSql" Version="3.10.0" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Projection.Core\Projection.Core.fsproj" />
    <ProjectReference Include="..\Projection.Adapters.Osm\Projection.Adapters.Osm.fsproj" />
    <ProjectReference Include="..\Projection.Adapters.OssysSql\Projection.Adapters.OssysSql.fsproj" />
    <ProjectReference Include="..\Projection.Adapters.Sql\Projection.Adapters.Sql.fsproj" />
    <ProjectReference Include="..\Projection.Targets.SSDT\Projection.Targets.SSDT.fsproj" />
    <ProjectReference Include="..\Projection.Targets.Json\Projection.Targets.Json.fsproj" />
    <ProjectReference Include="..\Projection.Targets.Distributions\Projection.Targets.Distributions.fsproj" />
    <ProjectReference Include="..\Projection.Targets.Data\Projection.Targets.Data.fsproj" />
    <ProjectReference Include="..\Projection.Targets.OperationalDiagnostics\Projection.Targets.OperationalDiagnostics.fsproj" />
  </ItemGroup>

</Project>
