# projection — local secret template (D9).
#
# These are the connection strings the env:<VAR> references in projection.json
# resolve to. They are SECRETS: keep them out of the committed config and out of
# the repo. This `.env.example` is the only committed copy.
#
#   1. cp .env.example .env          # .env is gitignored — never commit it
#   2. replace every REPLACE_ME      # one connection string per direct environment
#   3. load it into the shell session you run `projection` from:
#
#        set -a; source .env; set +a
#
# (`set -a` exports each assignment; the quotes keep the `;` / `=` / spaces in a
# connection string intact when sourced. Re-run it in any new shell.)
#
# Add one <NAME>_CONN per `direct` environment you declare. Maintain the values
# here (or in a secret manager you render into this file); the committed
# projection.json only ever names the references.

# --- Model source (read live via "modelOssys": "env:OSSYS_CONN") -------------
OSSYS_CONN="Server=tcp:cloud-uat.example.com,1433;Database=outsystems;User Id=svc_projection;Password=REPLACE_ME;Encrypt=true"

# --- Cloud OutSystems cells (physical rendition) -----------------------------
CLOUD_DEV_CONN="Server=tcp:cloud-dev.example.com,1433;Database=outsystems;User Id=svc_projection;Password=REPLACE_ME;Encrypt=true"
CLOUD_QA_CONN="Server=tcp:cloud-qa.example.com,1433;Database=outsystems;User Id=svc_projection;Password=REPLACE_ME;Encrypt=true"
CLOUD_UAT_CONN="Server=tcp:cloud-uat.example.com,1433;Database=outsystems;User Id=svc_projection;Password=REPLACE_ME;Encrypt=true"

# --- On-prem hosted model (logical rendition — the migration target) ---------
ONPREM_LEGACY_CONN="Server=tcp:onprem-legacy.example.local,1433;Database=migration;User Id=svc_projection;Password=REPLACE_ME;Encrypt=true"

# NOTE: PROJECTION_ALLOW_EXECUTE is deliberately NOT set here. It authorizes a
# live write and is stated per-command at the moment of action (intent), never
# persisted — `PROJECTION_ALLOW_EXECUTE=1 projection <flow> --go`.
